---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR, TAGLINE, SKILLS, SOCIAL } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = allProjects.filter((p) => p.data.featured).slice(0, 3);
const highlight = featured.length ? featured : allProjects.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
			}
			.hero {
				padding: 3em 0 1.5em;
				display: grid;
				grid-template-columns: 1.05fr 1fr;
				align-items: center;
				gap: 2.5em;
			}
			.hero-visual {
				padding: 0;
				overflow: hidden;
				line-height: 0;
				transform: perspective(1200px) rotateY(-4deg);
				transition: transform 0.4s ease;
			}
			.hero-visual:hover {
				transform: perspective(1200px) rotateY(0deg);
			}
			.hero-visual img {
				width: 100%;
				height: auto;
				display: block;
				border-radius: inherit;
			}
			@media (max-width: 820px) {
				.hero {
					grid-template-columns: 1fr;
					gap: 1.8em;
				}
				.hero-visual {
					transform: none;
					order: -1;
				}
			}
			.badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.35em 0.85em;
				margin-bottom: 1.2em;
				font-size: 0.85rem;
				font-weight: 500;
				color: rgb(var(--gray-dark));
				background: rgba(var(--accent-rgb), 0.08);
				border: 1px solid rgba(var(--accent-rgb), 0.25);
				border-radius: 999px;
			}
			.badge .dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #22c55e;
				box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
				animation: pulse 2s infinite;
			}
			@keyframes pulse {
				0% {
					box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
				}
				70% {
					box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
				}
				100% {
					box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
				}
			}
			.hero h1 {
				font-size: clamp(2.5rem, 6vw, 3.75rem);
				margin: 0 0 0.3em;
				line-height: 1.05;
			}
			.hero h1 .grad {
				background: linear-gradient(120deg, var(--accent), var(--accent-dark));
				-webkit-background-clip: text;
				background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 1.25rem;
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
				max-width: 38ch;
			}
			.cta {
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
			}
			.cta a {
				display: inline-block;
				padding: 0.7em 1.4em;
				border-radius: 10px;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95rem;
				transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
			}
			.cta a.primary {
				background: var(--accent);
				color: var(--on-accent);
				box-shadow: 0 6px 20px var(--accent-glow);
			}
			.cta a.primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 10px 28px var(--accent-glow);
			}
			.cta a.secondary {
				border: 1px solid var(--border);
				color: rgb(var(--gray-dark));
				background: rgba(var(--surface-rgb), 0.5);
			}
			.cta a.secondary:hover {
				border-color: rgba(var(--accent-rgb), 0.4);
				transform: translateY(-2px);
			}
			section {
				margin: 3.5em 0;
			}
			h2 {
				font-size: 1.6rem;
			}
			.skills {
				display: flex;
				flex-direction: column;
				gap: 0.9em;
			}
			.skill-group {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				gap: 0.5em;
			}
			.skill-group .group-label {
				font-weight: 600;
				min-width: 140px;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
			}
			.skill-group ul {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.skill-group li {
				padding: 0.25em 0.7em;
				font-size: 0.85rem;
				background: rgba(var(--surface-rgb), 0.6);
				border: 1px solid var(--border);
				border-radius: 999px;
				color: rgb(var(--gray-dark));
				transition: border-color 0.2s ease, color 0.2s ease;
			}
			.skill-group li:hover {
				border-color: rgba(var(--accent-rgb), 0.45);
				color: rgb(var(--black));
			}
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.2em;
			}
			.section-head h2 {
				margin: 0;
			}
			.section-head a {
				font-size: 0.95rem;
				text-decoration: none;
				font-weight: 500;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			@media (max-width: 720px) {
				.skill-group .group-label {
					min-width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Background />
		<Header />
		<main>
			<section class="hero reveal">
				<div class="hero-copy">
					<span class="badge"><span class="dot"></span>Available for projects</span>
					<h1>Hi, I'm <span class="grad">{AUTHOR}</span></h1>
					<p>{TAGLINE}</p>
					<div class="cta">
						<a class="primary" href="/projects">View projects</a>
						<a class="secondary" href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
						<a class="secondary" href={`mailto:${SOCIAL.email}`}>Contact</a>
					</div>
				</div>
				<div class="hero-visual glass-strong">
					<img src="/hero-terminal.svg" alt="Minimalist hacker-style terminal running a DevOps deploy session" width="760" height="560" loading="eager" />
				</div>
			</section>

			<section>
				<h2>Tech stack</h2>
				<div class="skills">
					{
						SKILLS.map((group) => (
							<div class="skill-group">
								<span class="group-label">{group.group}</span>
								<ul>
									{group.items.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						))
					}
				</div>
			</section>

			{
				highlight.length > 0 && (
					<section>
						<div class="section-head">
							<h2>Featured projects</h2>
							<a href="/projects">View all →</a>
						</div>
						<div class="grid">
							{highlight.map((project) => <ProjectCard project={project} />)}
						</div>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
