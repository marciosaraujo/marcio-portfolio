---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR, TAGLINE, SKILLS, SOCIAL } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = allProjects.filter((p) => p.data.featured).slice(0, 3);
const highlight = featured.length ? featured : allProjects.slice(0, 3);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
			}
			.hero {
				padding: 2em 0 1em;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 0.3em;
			}
			.hero p {
				font-size: 1.2rem;
				color: rgb(var(--gray));
				margin: 0 0 1.2em;
			}
			.cta {
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
			}
			.cta a {
				display: inline-block;
				padding: 0.6em 1.3em;
				border-radius: 8px;
				text-decoration: none;
				font-weight: 600;
			}
			.cta a.primary {
				background: var(--accent);
				color: white;
			}
			.cta a.secondary {
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			section {
				margin: 2.5em 0;
			}
			h2 {
				font-size: 1.5rem;
			}
			.skills {
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.skill-group {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				gap: 0.5em;
			}
			.skill-group .group-label {
				font-weight: 600;
				min-width: 130px;
				color: rgb(var(--gray-dark));
			}
			.skill-group ul {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.skill-group li {
				padding: 0.2em 0.6em;
				font-size: 0.85rem;
				background: rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--gray-dark));
			}
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
			}
			.section-head a {
				font-size: 0.95rem;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2rem;
				}
				.skill-group .group-label {
					min-width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Olá, sou {AUTHOR}</h1>
				<p>{TAGLINE}</p>
				<div class="cta">
					<a class="primary" href="/projects">Ver projetos</a>
					<a class="secondary" href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
					<a class="secondary" href={`mailto:${SOCIAL.email}`}>Contato</a>
				</div>
			</section>

			<section>
				<h2>Tecnologias</h2>
				<div class="skills">
					{
						SKILLS.map((group) => (
							<div class="skill-group">
								<span class="group-label">{group.group}</span>
								<ul>
									{group.items.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						))
					}
				</div>
			</section>

			{
				highlight.length > 0 && (
					<section>
						<div class="section-head">
							<h2>Projetos em destaque</h2>
							<a href="/projects">Ver todos →</a>
						</div>
						<div class="grid">
							{highlight.map((project) => <ProjectCard project={project} />)}
						</div>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
