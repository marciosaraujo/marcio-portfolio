---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, AUTHOR, SKILLS, SOCIAL } from '../consts';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`Sobre · ${SITE_TITLE}`} description={`Sobre ${AUTHOR}`} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
			}
			h2 {
				margin-top: 1.5em;
			}
			.skill-group {
				margin-bottom: 0.8em;
			}
			.skill-group strong {
				display: block;
				margin-bottom: 0.3em;
			}
			.contact a {
				display: inline-block;
				margin-right: 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Sobre</h1>
			<p>
				Sou {AUTHOR}, DevOps / SRE. Trabalho com automação, infraestrutura,
				confiabilidade e observabilidade de sistemas. Este site reúne projetos práticos
				que mostram como eu resolvo problemas de ponta a ponta.
			</p>
			<p>
				<!-- TODO: personalize com sua trajetória, experiência e o que você procura. -->
			</p>

			<h2>Tecnologias</h2>
			{
				SKILLS.map((group) => (
					<div class="skill-group">
						<strong>{group.group}</strong>
						<span>{group.items.join(' · ')}</span>
					</div>
				))
			}

			<h2>Contato</h2>
			<p class="contact">
				<a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
				<a href={`mailto:${SOCIAL.email}`}>{SOCIAL.email}</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
