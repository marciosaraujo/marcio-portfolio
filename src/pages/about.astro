---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import { SITE_TITLE, AUTHOR, SKILLS, SOCIAL } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description={`About ${AUTHOR}`} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
			}
			h2 {
				margin-top: 1.5em;
			}
			.skill-group {
				margin-bottom: 0.8em;
			}
			.skill-group strong {
				display: block;
				margin-bottom: 0.3em;
			}
			.contact a {
				display: inline-block;
				margin-right: 1em;
			}
			.lead {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				margin: 0.5em 0 1.5em;
			}
			.lead strong {
				color: rgb(var(--black));
			}
			.focus {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.6em;
			}
			.focus li {
				padding-left: 1.4em;
				position: relative;
				color: rgb(var(--gray-dark));
			}
			.focus li::before {
				content: '▸';
				position: absolute;
				left: 0;
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Background />
		<Header />
		<main>
			<h1>About</h1>
			<p class="lead">
				I work end to end: from infrastructure and automation to reliability,
				observability, and cloud cost, so engineering leaders get
				<strong>predictable delivery instead of firefighting</strong>. This site
				showcases hands-on projects that demonstrate how I design, implement, and
				evolve platforms that support real products in production.
			</p>

			<h2>What I focus on</h2>
			<ul class="focus">
				<li>Internal developer platforms that reduce toil and accelerate delivery.</li>
				<li>Infrastructure as Code and GitOps pipelines, from commit to production.</li>
				<li>Observability with SLOs and error budgets that drive concrete actions.</li>
				<li>Cloud cost and capacity (FinOps) treated as first-class metrics for the business.</li>
			</ul>

			<h2>Tech stack</h2>
			{
				SKILLS.map((group) => (
					<div class="skill-group">
						<strong>{group.group}</strong>
						<span>{group.items.join(' · ')}</span>
					</div>
				))
			}

			<h2>Contact</h2>
			<p class="contact">
				<a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
				<a href={`mailto:${SOCIAL.email}`}>{SOCIAL.email}</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
