---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import { SITE_TITLE, AUTHOR, SKILLS, SOCIAL } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description={`About ${AUTHOR}`} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
			}
			h2 {
				margin-top: 1.5em;
			}
			.skill-group {
				margin-bottom: 0.8em;
			}
			.skill-group strong {
				display: block;
				margin-bottom: 0.3em;
			}
			.contact a {
				display: inline-block;
				margin-right: 1em;
			}
		</style>
	</head>
	<body>
		<Background />
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm {AUTHOR}, a DevOps / SRE engineer. I work with automation,
				infrastructure, reliability and observability of systems. This site
				gathers hands-on projects that show how I solve problems end to end.
			</p>
			<p>
				<!-- TODO: personalize with your background, experience and what you're looking for. -->
			</p>

			<h2>Tech stack</h2>
			{
				SKILLS.map((group) => (
					<div class="skill-group">
						<strong>{group.group}</strong>
						<span>{group.items.join(' · ')}</span>
					</div>
				))
			}

			<h2>Contact</h2>
			<p class="contact">
				<a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>
				<a href={`mailto:${SOCIAL.email}`}>{SOCIAL.email}</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
