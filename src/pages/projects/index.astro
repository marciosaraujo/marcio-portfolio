---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Background from '../../components/Background.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SITE_TITLE, CATEGORY_LABELS } from '../../consts';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Only categories that actually have projects become filters.
const usedCategories = [...new Set(projects.map((p) => p.data.category))];
const filters = usedCategories.map((c) => ({ value: c, label: CATEGORY_LABELS[c] }));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects · ${SITE_TITLE}`} description="Hands-on projects by area." />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
			}
			h1 {
				margin-bottom: 0.2em;
			}
			.lead {
				color: rgb(var(--gray));
				margin-top: 0;
			}
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin: 1.5em 0;
			}
			.filters button {
				padding: 0.45em 1.1em;
				border: 1px solid var(--border);
				background: rgba(var(--surface-rgb), 0.5);
				border-radius: 999px;
				cursor: pointer;
				font-size: 0.9rem;
				font-weight: 500;
				color: rgb(var(--gray-dark));
				transition: 0.2s ease;
			}
			.filters button:hover {
				border-color: rgba(var(--accent-rgb), 0.4);
				color: rgb(var(--black));
			}
			.filters button[aria-pressed='true'] {
				background: var(--accent);
				border-color: var(--accent);
				color: var(--on-accent);
				box-shadow: 0 4px 14px var(--accent-glow);
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.card-wrap.hidden {
				display: none;
			}
		</style>
	</head>
	<body>
		<Background />
		<Header />
		<main>
			<h1>Projects</h1>
			<p class="lead">A selection of hands-on projects, organized by area.</p>

			<div class="filters" role="group" aria-label="Filter by category">
				<button data-filter="all" aria-pressed="true">All</button>
				{filters.map((f) => <button data-filter={f.value} aria-pressed="false">{f.label}</button>)}
			</div>

			<div class="grid" id="grid">
				{
					projects.map((project) => (
						<div class="card-wrap" data-category={project.data.category}>
							<ProjectCard project={project} />
						</div>
					))
				}
			</div>
		</main>
		<Footer />

		<script>
			const buttons = document.querySelectorAll<HTMLButtonElement>('.filters button');
			const cards = document.querySelectorAll<HTMLElement>('.card-wrap');

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => {
					const filter = btn.dataset.filter;
					buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
					cards.forEach((card) => {
						const show = filter === 'all' || card.dataset.category === filter;
						card.classList.toggle('hidden', !show);
					});
				});
			});
		</script>
	</body>
</html>
